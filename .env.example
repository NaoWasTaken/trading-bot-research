OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
DRY_RUN=true
FORWARD_TEST_MODE=false

# Optional bot settings
STRATEGY=ema_cross_v1
SELECTED_COMPARE_STRATEGY=rsi_reversion_v1
INSTRUMENT=EUR_USD
FOREX_INSTRUMENTS=EUR_USD,GBP_USD,USD_JPY,AUD_USD,USD_CAD,NZD_USD,EUR_JPY
TIMEFRAMES=M15,M30,H1,H4
GRANULARITY=M5
CANDLE_COUNT=200
FIXED_UNITS=100
TREND_FILTER_EMA_PERIOD=200
BREAKOUT_LOOKBACK=50
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
RSI_EXIT_LEVEL=50
RSI_ALLOW_SHORTS=false
# Filter modes default off. Use STRATEGY=rsi_reversion_filtered_v1 to apply them live/backtest.
RSI_FILTER_TREND_MODE=off
RSI_FILTER_ATR_MODE=off
RSI_FILTER_ATR_MEDIAN_PERIOD=100
RSI_FILTER_SESSION=off
ATR_PERIOD=14
ATR_MULTIPLIER=1.5
STOP_LOSS_PIPS=10
MAX_SPREAD_PIPS=2.0
BACKTEST_CANDLE_COUNT=1000
BACKTEST_START_DATE=
BACKTEST_END_DATE=
BACKTEST_STARTING_EQUITY=10000
BACKTEST_SPREAD_PIPS=1.5
BACKTEST_SLIPPAGE_PIPS=0.2
WALK_FORWARD_INSTRUMENT=GBP_USD
WALK_FORWARD_TIMEFRAME=H4
WALK_FORWARD_STRATEGY=rsi_reversion_v1
WALK_FORWARD_START_DATE=2020-01-01
WALK_FORWARD_END_DATE=2026-04-17
WALK_FORWARD_WINDOW_MONTHS=6
POLL_INTERVAL_SECONDS=300
